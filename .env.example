# SRE Decision Environment — secrets template
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# OpenRouter API key (required for Phase 1 LLM agent)
# Get your key at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here

# (Phase 3+) Hugging Face token for dataset upload / model download
# HF_TOKEN=your_hf_token_here

# (Phase 3+) Modal API token for trained model inference
# MODAL_TOKEN_ID=your_modal_token_id_here
# MODAL_TOKEN_SECRET=your_modal_token_secret_here
